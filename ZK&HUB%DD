local lockConn = nil
local hitpart = "Head"

local function getClosest()
    local target, near = nil, math.huge
    local camPos = workspace.CurrentCamera.CFrame.Position
    for _, p in pairs(players:GetPlayers()) do
        if p ~= plr and p.Character and p.Character:FindFirstChild(hitpart) and p.Character:FindFirstChildOfClass("Humanoid") then
            if p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
                local d = (p.Character[hitpart].Position - camPos).Magnitude
                if d < near then near = d; target = p end
            end
        end
    end
    return target
end

ctx_toggle(combat_p, "Cam Lock (Aimbot)", function(v)
    if v then
        lockConn = run.RenderStepped:Connect(function()
            local t = getClosest()
            if t and t.Character and t.Character:FindFirstChild(hitpart) then
                workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, t.Character[hitpart].Position)
            end
        end)
    else
        if lockConn then lockConn:Disconnect(); lockConn = nil end
    end
end)


-- ==================== [ VISUALS - RECONSTRUCTION TOTALE (API DRAWING) ] ====================
local function cleanESP(p)
    if p.Character then
        local hl = p.Character:FindFirstChild("ZK_Highlight")
        if hl then hl:Destroy() end
        local bb = p.Character:FindFirstChild("ZK_NameTag")
        if bb then bb:Destroy() end
    end
    if activeTracers[p] then
        activeTracers[p].Visible = false
        activeTracers[p]:Remove()
        activeTracers[p] = nil
    end
end

local function applyESP(p)
    if p == plr then return end
    cleanESP(p)

    local function runESP()
        local char = p.Character
        if not char then return end
        
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        local head = char:WaitForChild("Head", 5)
        if not hrp or not head then return end

        -- 1. CHAMS (Silhouette)
        local hl = Instance.new("Highlight")
        hl.Name = "ZK_Highlight"
        hl.FillColor = Color3.fromRGB(50, 110, 255)
        hl.FillTransparency = 0.4
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.Enabled = espOn
        hl.Parent = char

        -- 2. TEXTE (Noms & Distance via Billboard natif Roblox)
        local bb = Instance.new("BillboardGui")
        bb.Name = "ZK_NameTag"
        bb.Size = UDim2.new(0, 150, 0, 30)
        bb.AlwaysOnTop = true
        bb.Adornee = head
        bb.ExtentsOffset = Vector3.new(0, 2.5, 0)
        
        local tl = Instance.new("TextLabel")
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.TextColor3 = Color3.fromRGB(255, 255, 255)
        tl.TextStrokeTransparency = 0
        tl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        tl.Font = Enum.Font.GothamBold
        tl.TextSize = 13
        tl.Visible = (espOn and espNames)
        tl.Parent = bb
        bb.Parent = char

        -- 3. TRACERS (Lignes via Drawing API)
        local line = Drawing.new("Line")
        line.Color = Color3.fromRGB(50, 110, 255)
        line.Thickness = 2
        line.Transparency = 1
        activeTracers[p] = line

        local connection
        connection = run.RenderStepped:Connect(function()
            if not espOn or not p.Parent or not char.Parent or not hrp.Parent then
                cleanESP(p)
                if connection then connection:Disconnect() end
                return
            end

            -- Actualisation dynamique des Noms & Distance
            if espNames then
                local dist = 0
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    dist = math.floor((hrp.Position - plr.Character.HumanoidRootPart.Position).Magnitude)
                end
                local dispName = (p.DisplayName and p.DisplayName ~= "") and p.DisplayName or p.Name
                tl.Text = dispName .. " [" .. dist .. "m]"
                tl.Visible = true
            else
                tl.Visible = false
            end

            -- Actualisation dynamique du Traceur (Drawing API direct)
            if espTracers then
                local cam = workspace.CurrentCamera
                local screenPos, onScreen = cam:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    line.From = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
                    line.To = Vector2.new(screenPos.X, screenPos.Y)
                    line.Visible = true
                else
                    line.Visible = false
                end
            else
                line.Visible = false
            end
        end)
    end

    if p.Character then task.spawn(runESP) end
    p.CharacterAdded:Connect(runESP)
end

