local bClips = false
run.Heartbeat:Connect(function()
    if bClips and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        local parts = workspace:GetPartsInPart(plr.Character.HumanoidRootPart)
        for _, p in pairs(parts) do
            if not p:IsDescendantOf(plr.Character) and p.CanCollide == true and p.Size.Magnitude < 50 then p:Destroy() end
        end
    end
end)
ctx_toggle(world_p, "Insta-Break Murs touchés", function(v) bClips = v end)
